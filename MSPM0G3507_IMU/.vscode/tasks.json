{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "${command:eide.project.build}",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "flash",
            "type": "shell",
            "command": "${command:eide.project.uploadToDevice}",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "build and flash",
            "type": "shell",
            "command": "${command:eide.project.buildAndFlash}",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "flash fast no verify",
            "type": "shell",
            "command": "D:/diansai/ti/openocd/bin/openocd.exe",
            "args": [
                "-s",
                "D:/diansai/ti/openocd/share/openocd/scripts",
                "-f",
                "interface/xds110.cfg",
                "-f",
                "target/ti_mspm0.cfg",
                "-c",
                "adapter speed 2500",
                "-c",
                "program \"${workspaceFolder}/build/Debug/MSPM0G3507_IMU.elf\" reset exit"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "build and flash fast no verify",
            "dependsOrder": "sequence",
            "dependsOn": [
                "build",
                "flash fast no verify"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "rebuild",
            "type": "shell",
            "command": "${command:eide.project.rebuild}",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "${command:eide.project.clean}",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Open SysConfig",
            "type": "shell",
            "command": "${workspaceFolder}\\tools\\open_syscfg.cmd",
            "problemMatcher": [],
            "presentation": {
                "reveal": "never",
                "panel": "dedicated"
            }
        }
    ]
}
